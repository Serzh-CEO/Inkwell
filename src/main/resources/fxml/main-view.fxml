<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.inkwell.controller.MainViewController">
    <left>
        <VBox spacing="6.0" styleClass="sidebar">
            <padding>
                <Insets bottom="20.0" left="14.0" right="14.0" top="20.0" />
            </padding>
            <Label styleClass="sidebar-title" text="Inkwell" />
            <Label styleClass="sidebar-subtitle" text="Story workspace" />
            <Region prefHeight="16.0" />
            <Button fx:id="storiesNavButton" maxWidth="1.7976931348623157E308"
                    mnemonicParsing="false" onAction="#onStoriesNavClick"
                    text="Stories" styleClass="nav-button" />
            <Button fx:id="charactersNavButton" maxWidth="1.7976931348623157E308"
                    mnemonicParsing="false" onAction="#onCharactersNavClick"
                    text="Characters" styleClass="nav-button" />
            <Button fx:id="graphNavButton" maxWidth="1.7976931348623157E308"
                    mnemonicParsing="false" onAction="#onGraphNavClick"
                    text="Graph" styleClass="nav-button" />
            <Region VBox.vgrow="ALWAYS" />
            <Separator styleClass="sidebar-separator" />
            <Label styleClass="sidebar-section-label" text="PROJECT" />
            <ComboBox fx:id="projectComboBox" maxWidth="1.7976931348623157E308" />
            <HBox spacing="8.0">
                <Button mnemonicParsing="false" onAction="#onCreateProjectClick"
                        text="+ New" styleClass="btn-secondary"
                        maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#onDeleteProjectClick"
                        text="Delete" styleClass="btn-danger" />
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0.0" styleClass="content">
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12.0">
                <padding>
                    <Insets bottom="14.0" left="20.0" right="20.0" top="14.0" />
                </padding>
                <Label fx:id="contentTitleLabel" styleClass="content-title" text="Stories" />
            </HBox>
            <Separator styleClass="topbar-separator" />

            <StackPane VBox.vgrow="ALWAYS">
                <padding>
                    <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                </padding>

                <!-- ══════════════ STORIES VIEW ══════════════ -->
                <VBox fx:id="storiesView" spacing="12.0">

                    <!-- Toolbar -->
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <TextField fx:id="storySearchField" onAction="#onStorySearchClick"
                                   promptText="Search stories..." styleClass="search-field"
                                   prefWidth="220.0" />
                        <ComboBox fx:id="tagFilterComboBox" prefWidth="160.0" promptText="All tags" />
                        <Button mnemonicParsing="false" onAction="#onStorySearchClick"
                                text="Search" styleClass="btn-secondary" />
                        <Button mnemonicParsing="false" onAction="#onStoryClearFiltersClick"
                                text="Clear" styleClass="btn-ghost" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onNewStoryClick"
                                text="+ New Story" styleClass="btn-primary" />
                        <Button mnemonicParsing="false" onAction="#onCreateStoryGroupClick"
                                text="+ Group" styleClass="btn-secondary" />
                        <Button mnemonicParsing="false" onAction="#onDeleteStoryClick"
                                text="Delete" styleClass="btn-danger" />
                    </HBox>

                    <!-- Content area: list + optional editor side-by-side -->
                    <HBox fx:id="storiesContentArea" spacing="12.0" VBox.vgrow="ALWAYS">

                        <!-- List panel — full width when editor hidden, narrows when editor shown -->
                        <VBox fx:id="storiesListPanel" styleClass="list-panel" HBox.hgrow="ALWAYS">
                            <ListView fx:id="storiesListView" VBox.vgrow="ALWAYS" />
                        </VBox>

                        <!-- Editor panel — hidden until item selected or New clicked -->
                        <VBox fx:id="storyEditorPanel" spacing="10.0" styleClass="editor-panel"
                              managed="false" visible="false" prefWidth="500.0" minWidth="400.0">
                            <padding>
                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                            </padding>

                            <!-- Header row: back button + expand toggles -->
                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                <Button fx:id="storyBackButton" mnemonicParsing="false"
                                        onAction="#onStoryBackClick"
                                        text="← Back to list" styleClass="btn-ghost" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="storyExpandButton" mnemonicParsing="false"
                                        onAction="#onStoryExpandClick"
                                        text="⤢ Expand" styleClass="btn-ghost" />
                            </HBox>

                            <Separator fx:id="storyTopSeparator" styleClass="topbar-separator" />

                            <!-- Fields hidden when content is expanded -->
                            <VBox fx:id="storyMetaFields" spacing="10.0">
                                <Label styleClass="editor-section-label" text="STORY DETAILS" />
                                <TextField fx:id="storyTitleField" promptText="Title" />
                                <HBox spacing="8.0">
                                    <TextField fx:id="storyCategoryField"
                                               promptText="Category (e.g. Fantasy)"
                                               HBox.hgrow="ALWAYS" />
                                    <TextField fx:id="storyTagsField"
                                               promptText="Tags, comma separated"
                                               HBox.hgrow="ALWAYS" />
                                </HBox>
                                <Label styleClass="editor-section-label" text="SUMMARY" />
                                <TextArea fx:id="storySummaryArea" prefHeight="90.0"
                                          promptText="Brief synopsis of this story..."
                                          wrapText="true" />
                            </VBox>

                            <VBox fx:id="storyContentEditorContainer" VBox.vgrow="ALWAYS" spacing="4.0" />

                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                <Button mnemonicParsing="false" onAction="#onSaveStoryClick"
                                        text="Save Story" styleClass="btn-primary" />
                                <Button mnemonicParsing="false" onAction="#onNewStoryClick"
                                        text="Reset" styleClass="btn-ghost" />
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ══════════════ CHARACTERS VIEW ══════════════ -->
                <VBox fx:id="charactersView" managed="false" spacing="12.0" visible="false">

                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <Button mnemonicParsing="false" onAction="#onNewCharacterClick"
                                text="+ New Character" styleClass="btn-primary" />
                        <Button mnemonicParsing="false" onAction="#onCreateCharacterGroupClick"
                                text="+ Group" styleClass="btn-secondary" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#onDeleteCharacterClick"
                                text="Delete" styleClass="btn-danger" />
                    </HBox>

                    <HBox fx:id="charactersContentArea" spacing="12.0" VBox.vgrow="ALWAYS">

                        <VBox fx:id="charactersListPanel" styleClass="list-panel" HBox.hgrow="ALWAYS">
                            <ListView fx:id="charactersListView" VBox.vgrow="ALWAYS" />
                        </VBox>

                        <VBox fx:id="characterEditorPanel" spacing="10.0" styleClass="editor-panel"
                              managed="false" visible="false" prefWidth="500.0" minWidth="400.0">
                            <padding>
                                <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
                            </padding>

                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                <Button fx:id="characterBackButton" mnemonicParsing="false"
                                        onAction="#onCharacterBackClick"
                                        text="← Back to list" styleClass="btn-ghost" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="characterExpandButton" mnemonicParsing="false"
                                        onAction="#onCharacterExpandClick"
                                        text="⤢ Expand" styleClass="btn-ghost" />
                            </HBox>

                            <Separator styleClass="topbar-separator" />

                            <!-- Fields hidden when description is expanded -->
                            <VBox fx:id="characterMetaFields" spacing="10.0">
                                <Label styleClass="editor-section-label" text="CHARACTER DETAILS" />
                                <TextField fx:id="characterNameField" promptText="Character name" />

                                <VBox spacing="4.0">
                                    <Label styleClass="field-label" text="Linked story" />
                                    <ComboBox fx:id="characterStoryComboBox"
                                              maxWidth="1.7976931348623157E308"
                                              promptText="No linked story" />
                                </VBox>

                                <TextField fx:id="characterTraitsField"
                                           promptText="Traits, comma separated (e.g. brave, stubborn)" />
                            </VBox>

                            <VBox fx:id="characterDescEditorContainer" VBox.vgrow="ALWAYS" spacing="4.0" />

                            <HBox spacing="8.0" alignment="CENTER_LEFT">
                                <Button mnemonicParsing="false" onAction="#onSaveCharacterClick"
                                        text="Save Character" styleClass="btn-primary" />
                                <Button mnemonicParsing="false" onAction="#onNewCharacterClick"
                                        text="Reset" styleClass="btn-ghost" />
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ══════════════ GRAPH VIEW ══════════════ -->
                <VBox fx:id="graphView" managed="false" spacing="10.0" visible="false">
                    <HBox spacing="16.0" alignment="CENTER_LEFT" styleClass="graph-hint-bar">
                        <padding>
                            <Insets bottom="8.0" left="12.0" right="12.0" top="8.0" />
                        </padding>
                        <Button mnemonicParsing="false" onAction="#onGraphRefreshClick"
                                text="Refresh" styleClass="btn-secondary" />
                        <Separator orientation="VERTICAL" />
                        <Label styleClass="legend-story" text="Story" />
                        <Label styleClass="legend-character" text="Character" />
                        <Label styleClass="legend-rel" text="- Relationship" />
                        <Separator orientation="VERTICAL" />
                        <Label styleClass="muted-text" text="Drag to move  |  Scroll to zoom  |  Click to open" />
                    </HBox>

                    <ScrollPane fitToHeight="true" fitToWidth="true" pannable="true" VBox.vgrow="ALWAYS">
                        <content>
                            <Pane fx:id="graphPane"
                                  minHeight="1200.0" minWidth="1800.0"
                                  prefHeight="1200.0" prefWidth="1800.0"
                                  styleClass="graph-pane" />
                        </content>
                    </ScrollPane>
                </VBox>

            </StackPane>
        </VBox>
    </center>
</BorderPane>
